---
// Orion Web Service cross-sell strip — sister business. Site-wide pre-footer band.
// Top line = THIS site's native accent (--c-mint); Orion cyan kept for its identity.
---
<section class="orion-section">
  <div class="orion-inner">
    <div class="orion-eyebrow">★ Sister business · Orion Web Service</div>
    <h3 class="orion-headline">Need faster hosting, or the team behind Asteris to build your site?</h3>
    <p class="orion-body">Orion Web Service runs your WordPress and WooCommerce site on Google Cloud and AWS, fronted by Cloudflare CDN globally. Same Sydney team as Asteris. Building and hosting real client stores since 2021.</p>
    <a href="https://orionwebservice.com/?utm_source=asterisaffiliates&utm_medium=site-section&utm_campaign=cross-sell" class="orion-cta" target="_blank" rel="noopener">Visit Orion Web Service →</a>
  </div>
</section>
<style>
  .orion-section { background:#0a0a0a; color:#fff; padding:72px 0; border-top:4px solid var(--c-mint,#06D6A0); }
  .orion-inner { max-width:1100px; margin:0 auto; padding:0 24px; }
  .orion-eyebrow { color:#56dbda; font-size:17px; font-weight:700; letter-spacing:.5px; text-transform:uppercase; margin-bottom:18px; }
  .orion-headline { font-size:34px; line-height:1.2; font-weight:800; letter-spacing:-.5px; color:#fff; margin:0 0 18px; }
  .orion-body { font-size:22px; line-height:1.55; color:#cccccc; margin:0 0 28px; max-width:70ch; }
  .orion-cta { display:inline-block; background:#fff; color:#0a0a0a; border:2px solid #fff; padding:16px 26px; font-weight:700; font-size:18px; text-decoration:none; border-radius:8px; box-shadow:4px 4px 0 #56dbda; transition:transform .1s, box-shadow .1s; }
  .orion-cta:hover { transform:translate(-2px,-2px); box-shadow:6px 6px 0 #56dbda; }
  @media (max-width:700px){ .orion-headline{font-size:26px;} .orion-body{font-size:18px;} }
</style>
