---
/**
 * Interactive Comparator — v1.1 SCAFFOLD (not interactive yet).
 *
 * Renders a static "what would I save" table now so the data shape and
 * styling are locked in. The v1.1 build will replace the static render
 * with checkbox state + recalc — either via Astro client islands (Preact
 * or React when the integration is added), or via a small vanilla JS
 * sprinkle. The data and pricing maths are already correct; only the
 * interactivity is pending.
 *
 * Full spec: 02-specs/research/strategy/07_INTERACTIVE_COMPARATOR_SPEC.md
 *
 * To build v1.1:
 *   1. Add @astrojs/react (or @astrojs/preact) to package.json
 *   2. Convert this file to Comparator.jsx with useState for selection
 *   3. Render with <Comparator client:visible /> on /modules + /pricing
 *   4. Create the canonical /tools/plugin-cost-calculator route
 *   5. Add the embeddable iframe variant for Reddit/X posts
 *   6. WCAG-AA pass (keyboard nav, ARIA labels, 44x44px tap targets per
 *      research/strategy/07_INTERACTIVE_COMPARATOR_SPEC.md §6)
 *   7. Email-capture endpoint for "save my list" (CF Worker)
 */

import { competitors, ASTERIS_PRICING } from '../data/competitor-plugins';

interface Props {
  /** When true, renders the full grid + tally. Default. */
  full?: boolean;
  /** When true, renders a compact sidebar mode for /pricing. */
  compact?: boolean;
  /** Optional pre-checked plugin IDs (for embeds / direct links). */
  preselect?: string[];
}

const { full = true, compact = false, preselect = [] } = Astro.props;

// Group competitors by category for display.
const byCategory = competitors.reduce((acc, p) => {
  (acc[p.category] ||= []).push(p);
  return acc;
}, {} as Record<string, typeof competitors>);

const categoryLabels: Record<string, string> = {
  seo: 'SEO',
  ai: 'AI content',
  invoices: 'PDF Invoices',
  swatches: 'Variation Swatches',
  wishlist: 'Wishlist',
  quote: 'Quote / Enquiry',
  back_in_stock: 'Back in Stock',
  cart: 'Side Cart / Funnels',
  order_numbers: 'Sequential Order Numbers',
  filtering: 'Product Filtering',
  min_max: 'Min/Max Quantity',
  links: 'Link shortener',
  trust_badges: 'Trust Badges',
  shipping_bar: 'Free Shipping Bar',
  stock_urgency: 'Stock Urgency',
  delivery: 'Delivery Timeline',
  labels: 'Feature Labels',
  badges: 'Product Badges',
  analytics: 'Analytics',
};

// At v1.0 we render the full list as-is (no interactivity). The "pre-checked"
// items get a static highlighted look so embedded links can still link to a
// pre-filled view that's at least visually communicative.
const preselectSet = new Set(preselect);
---

<aside class="comparator-scaffold" aria-label="Interactive plugin cost comparator (v1.1)">
  <div class="comparator-header">
    <span class="badge">v1.1 preview</span>
    <h3>What you currently pay for, vs Asteris</h3>
    <p class="lead">
      This grid lists every plugin Asteris replaces, with current annual pricing. In v1.1 the checkboxes
      become interactive — tick what you pay for, see your spend vs Asteris in real time. For now this is
      a reference list.
    </p>
  </div>

  <div class="comparator-grid">
    {Object.entries(byCategory).map(([cat, items]) => (
      <fieldset class="category">
        <legend>{categoryLabels[cat] ?? cat}</legend>
        <ul>
          {items.map(p => (
            <li class:list={['plugin-row', { preselected: preselectSet.has(p.id) }]}>
              <label>
                <input type="checkbox" disabled checked={preselectSet.has(p.id)} aria-label={`Select ${p.name}`} />
                <span class="name">{p.name}</span>
                <span class="vendor">{p.vendor}</span>
                <span class="price">${p.yearlyUsd}<span class="per">/yr</span></span>
              </label>
            </li>
          ))}
        </ul>
      </fieldset>
    ))}
  </div>

  <div class="comparator-cta">
    <p class="hint">
      <strong>Coming in v1.1:</strong> tick the plugins you actually use; the widget shows your annual spend,
      how many modules Asteris covers, and which Asteris tier gives the fastest payback. Until then, see
      Asteris pricing directly.
    </p>
    <a class="btn btn-pop" href="/pricing">See Asteris pricing →</a>
  </div>
</aside>

<style>
  .comparator-scaffold {
    background: var(--c-white);
    border: 2px solid var(--c-black);
    border-radius: var(--r-md);
    padding: 28px;
    margin: 32px 0;
  }
  .comparator-header { margin-bottom: 24px; }
  .badge {
    display: inline-block;
    background: var(--c-yellow);
    color: var(--c-black);
    padding: 3px 10px;
    border-radius: var(--r-sm);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 1px;
    margin-bottom: 10px;
  }
  .comparator-header h3 {
    font-size: 28px;
    font-weight: 900;
    letter-spacing: -0.8px;
    margin-bottom: 10px;
  }
  .comparator-header .lead {
    font-size: 15px;
    color: #444;
    line-height: 1.55;
    max-width: 760px;
  }
  .comparator-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }
  .category {
    border: 1px solid var(--c-border);
    border-radius: var(--r-sm);
    padding: 14px 16px;
  }
  .category legend {
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--c-mint);
    padding: 0 6px;
  }
  .category ul { list-style: none; margin: 0; padding: 0; }
  .plugin-row {
    padding: 6px 0;
    border-bottom: 1px dashed var(--c-border);
  }
  .plugin-row:last-child { border-bottom: 0; }
  .plugin-row label {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: not-allowed;
    opacity: 0.85;
  }
  .plugin-row.preselected label { opacity: 1; }
  .plugin-row input[type='checkbox'] { margin: 0; }
  .plugin-row .name { font-size: 13px; font-weight: 600; flex: 1; }
  .plugin-row .vendor { font-size: 11px; color: #888; }
  .plugin-row .price { font-size: 12px; color: var(--c-mint); font-weight: 700; white-space: nowrap; }
  .plugin-row .per { color: #888; font-weight: 500; }

  .comparator-cta {
    background: var(--c-yellow);
    border: 1px solid var(--c-black);
    border-radius: var(--r-sm);
    padding: 18px;
    text-align: center;
  }
  .comparator-cta .hint {
    font-size: 14px;
    color: var(--c-black);
    margin-bottom: 14px;
    line-height: 1.5;
  }
</style>
