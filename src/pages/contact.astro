---
import Layout from '../layouts/Layout.astro';
---
<Layout seoSlug="/contact">
  <section class="hero">
    <div class="eyebrow">★ A SMALL AUSTRALIAN TEAM · AU BUSINESS HOURS</div>
    <h1>Get in <span class="accent">touch</span></h1>
    <p class="lead">Pre-sales questions, support, migration help, partnerships, press — one inbox, one team, replies within one business day.</p>
  </section>

  <section class="contact">
    <div class="contact-inner">
      <a href="mailto:support@asterisaffiliates.com" class="contact-card single">
        <h2>Email us</h2>
        <p>Bugs, account, technical questions, pricing, evaluation, migration help, partnerships, press — all go to the same inbox.</p>
        <span class="email">support@asterisaffiliates.com</span>
      </a>
    </div>
  </section>

  <section class="legal-strip">
    <div class="legal-inner">
      <p>My Cosmic Message Pty Ltd t/a Asteris Commerce · ABN 30 652 358 159 · Sydney, Australia</p>
    </div>
  </section>
</Layout>

<style>
  .hero { max-width: 760px; margin: 0 auto; padding: 96px 24px 48px; text-align: center; }
  .eyebrow { font-size: 13px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--c-muted); margin-bottom: 16px; }
  .hero h1 { font-size: clamp(36px, 5vw, 52px); font-weight: 900; line-height: 1.1; margin-bottom: 20px; }
  .hero h1 .accent { color: var(--c-mint); }
  .hero .lead { font-size: 18px; color: var(--c-text); line-height: 1.6; }
  .contact { padding: 32px 24px 64px; }
  .contact-inner { max-width: 640px; margin: 0 auto; }
  .contact-card { display: block; padding: 40px 32px; background: #fff; border: 2px solid var(--c-border); border-radius: 10px; text-decoration: none; color: inherit; transition: border-color 0.15s; text-align: center; }
  .contact-card:hover { border-color: var(--c-mint); }
  .contact-card.single { box-shadow: 6px 6px 0 var(--c-mint); border-color: var(--c-mint); }
  .contact-card h2 { font-size: 22px; margin-bottom: 12px; }
  .contact-card p { color: var(--c-muted); margin-bottom: 20px; font-size: 15px; line-height: 1.55; max-width: 460px; margin-left: auto; margin-right: auto; }
  .contact-card .email { color: var(--c-mint); font-weight: 800; font-size: 19px; letter-spacing: -0.01em; }
  .legal-strip { padding: 48px 24px; background: var(--c-bg); text-align: center; color: var(--c-muted); font-size: 13px; }
</style>
